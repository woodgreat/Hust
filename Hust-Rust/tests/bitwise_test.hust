void main() {
    i32 a = 5;   // 二进制: 101
    i32 b = 3;   // 二进制: 011
    
    i32 c = a & b;   // 位与:  001 = 1
    i32 d = a | b;   // 位或:  111 = 7
    i32 e = a ^ b;   // 位异或: 110 = 6
    i32 f = a << 1;  // 左移:  1010 = 10
    i32 g = a >> 1;  // 右移:  10 = 2
    
    println!("a & b = {}", c);
    println!("a | b = {}", d);
    println!("a ^ b = {}", e);
    println!("a << 1 = {}", f);
    println!("a >> 1 = {}", g);
}
