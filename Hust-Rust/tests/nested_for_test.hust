void main() {
    i32[5] arr = {5, 2, 8, 1, 3};

    // nested for loop test
    for(i16 i=0; i<4; i++)
    {
        for(i16 j=0; j<4; j++)
        {
            if(arr[j] > arr[j+1])
            {
                i32 temp = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            }
        }
    }

    println!("Sorted: {} {} {} {} {}", arr[0], arr[1], arr[2], arr[3], arr[4]);
}