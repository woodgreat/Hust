// Main module - uses math module

use math;

void main() {
    i32 x = 10;
    i32 y = 5;

    i32 sum = add(x, y);
    i32 diff = subtract(x, y);
    i32 prod = multiply(x, y);

    println!("x = {}", x);
    println!("y = {}", y);
    println!("add(x, y) = {}", sum);
    println!("subtract(x, y) = {}", diff);
    println!("multiply(x, y) = {}", prod);

    println!("Module test passed!");
}
