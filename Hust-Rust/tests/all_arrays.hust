void main() {
    // 1. Fixed array
    i32[3] fixed = {10, 20, 30};
    println!("Fixed array:");
    for (i32 i = 0; i < 3; i = i + 1) {
        println!("  {}", fixed[i]);
    }

    // 2. Dynamic array
    i32[] dynamic;
    dynamic.push(100);
    dynamic.push(200);
    dynamic.push(300);
    println!("Dynamic array:");
    for (i32 i = 0; i < dynamic.len(); i = i + 1) {
        println!("  {}", dynamic[i]);
    }

    // 3. Multi-dimensional array
    i32[2][3] matrix = {
        {1, 2, 3},
        {4, 5, 6}
    };
    println!("Matrix:");
    for (i32 i = 0; i < 2; i = i + 1) {
        for (i32 j = 0; j < 3; j = j + 1) {
            print!("{} ", matrix[i][j]);
        }
        println!("");
    }

    println!("All array types work!");
}
